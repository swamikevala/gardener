#!/usr/bin/env bash
# gardener codex-exec — reliable non-interactive codex invocation (from a Claude
# cockpit, a cron, or any script).
#
# Encapsulates two hard-won fixes:
#   1. sandbox: codex's Linux sandbox (bubblewrap) needs unprivileged user
#      namespaces; on Ubuntu 24.04+ that requires an AppArmor profile for bwrap
#      (see gardener WORKING-METHOD.md "Host setup"). With that in place the
#      sandbox WORKS — never fall back to --dangerously-bypass flags.
#   2. stdin: `codex exec` reads stdin; a backgrounded call without redirection
#      can hang until killed. Always </dev/null here.
#
# Usage:
#   codex-exec <prompt-file> [--cd <dir>] [--write] [--timeout <secs>] [--model <id>]
# The prompt comes from a FILE (keeps shell-quoting sane, transcript reviewable).

set -uo pipefail

PROMPT_FILE="${1:?usage: codex-exec <prompt-file> [--cd dir] [--write] [--timeout secs]}"
shift
CD_DIR="$HOME"
SANDBOX="read-only"
TIMEOUT=600
MODEL=""

while (($#)); do
    case "$1" in
        --cd)      CD_DIR="$2"; shift 2 ;;
        --write)   SANDBOX="workspace-write"; shift ;;
        --full)    SANDBOX="danger-full-access"; shift ;;  # network/system access; use for impl phases that need it
        --timeout) TIMEOUT="$2"; shift 2 ;;
        --model)   MODEL="$2"; shift 2 ;;
        *) echo "unknown arg: $1" >&2; exit 2 ;;
    esac
done

[[ -r "$PROMPT_FILE" ]] || { echo "prompt file not readable: $PROMPT_FILE" >&2; exit 2; }

# The workspace-write sandbox denies ~/.cache; uv needs a writable cache or it
# fails/hangs acquiring locks (root cause of the 2026-07-03 "hanging suite").
export UV_CACHE_DIR="${UV_CACHE_DIR:-/tmp/uv-cache-codex}"

MODEL_ARGS=()
[[ -n "$MODEL" ]] && MODEL_ARGS=(--model "$MODEL")

# --- Serialization lease -------------------------------------------------
# One codex-exec at a time across the whole box: protects the shared
# gpt-5.6-sol quota (no two runs competing for tokens) and prevents the
# parallel-worktree collisions we've been bitten by. Blocks until the lock is
# free, then dispatches; the lock auto-releases when this process exits — even
# on SIGKILL — so there are no stale locks. Order is by arrival: whoever is
# waiting when the holder finishes goes next, so a backlog drains one-by-one.
# Bypass a single run with CODEX_EXEC_NOLOCK=1 when you deliberately want
# parallelism (e.g. a multi-lens panel).
if [[ "${CODEX_EXEC_NOLOCK:-0}" != "1" ]] && command -v flock >/dev/null 2>&1; then
    CODEX_EXEC_LOCK="${CODEX_EXEC_LOCK:-$HOME/.codex/codex-exec.lock}"
    if ( : >>"$CODEX_EXEC_LOCK" ) 2>/dev/null; then
        exec 9>>"$CODEX_EXEC_LOCK"           # fd 9 survives the exec below → held for codex's lifetime
        echo "codex-exec: acquiring codex lease ($CODEX_EXEC_LOCK)…" >&2
        if flock -w 90000 9; then
            echo "codex-exec: lease acquired, dispatching." >&2
        else
            echo "codex-exec: WARN lease wait exceeded 25h; proceeding unserialized." >&2
        fi
    else
        echo "codex-exec: WARN cannot open lease $CODEX_EXEC_LOCK; running unserialized." >&2
    fi
fi

exec timeout "$TIMEOUT" codex exec \
    --sandbox "$SANDBOX" \
    --skip-git-repo-check \
    --cd "$CD_DIR" \
    "${MODEL_ARGS[@]}" \
    "$(cat "$PROMPT_FILE")" </dev/null
